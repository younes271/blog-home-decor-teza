# On-demand ISR revalidation secret (must match REVALIDATION_SECRET in Factory API)
REVALIDATION_SECRET=your-secret-here

# Next.js public URL (used for canonical URLs and sitemap)
NEXT_PUBLIC_SITE_URL=https://your-blog.vercel.app

# Google Analytics measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# Google AdSense client ID (optional, e.g. ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
